// This schema is for the Spring Boot Contracts Microservice
// Shares the same PostgreSQL database as the general Next.js app
// 
// Architecture:
// - Database: clm_platform (single database)
// - Spring Boot uses: "contracts" schema with JPA/Hibernate ORM
// - Next.js uses: "public" schema with Prisma ORM
// 
// The Prisma schema here is a placeholder for documentation purposes.
// The Spring Boot service will manage the contracts schema through its own
// JPA entities and database migrations (Liquibase/Flyway).
//
// Configuration:
// - Spring Boot JDBC URL: jdbc:postgresql://localhost:5432/clm_platform
// - Schema: contracts
// - Spring Hibernate dialect: org.hibernate.dialect.PostgreSQL10Dialect

generator client {
  provider = "prisma-client-js"
  output   = "../lib/prisma-client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["contracts"]
}

